{
  "name": "claude-context-handoff-skill",
  "version": "0.1.0",
  "description": "Path-aware Claude Skill and CLI for handing off Claude Code context between repositories.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.27.0",
  "bin": {
    "claude-context-handoff": "./dist/cli.js"
  },
  "files": [
    "dist",
    "SKILL.md",
    "SKILL-ko.md",
    "agents",
    "examples",
    "LICENSE",
    "README.md",
    "README-ko.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/cli.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.10.1",
    "commander": "^14.0.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.0",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "vitest": "^4.0.0"
  }
}
